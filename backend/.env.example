# 应用配置
APP_NAME=BOSS_RPA
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production

# 服务器配置
HOST=0.0.0.0
PORT=8000

# MongoDB配置
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=boss_rpa

# CORS配置
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# 日志配置
LOG_LEVEL=INFO
LOG_PATH=../logs

# RPA配置
RPA_HEADLESS=False
RPA_TIMEOUT=30000

# BOSS直聘配置
BOSS_URL=https://www.zhipin.com
